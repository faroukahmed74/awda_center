rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // patient_docs/{patientId}/{filename} - authenticated users can read; patient and doctor/admin can write
    match /patient_docs/{patientId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
